<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Terrabuild{% endblock %}</title>
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <style>
          :root {
            --header: #a08969;
            --header-dark: #6d5a43;
            --pill: #cfb88f;
          }
          body {
            margin: 0;
            font: 14px/1.35 "Trebuchet MS", Segoe UI, Roboto, system-ui, -apple-system, sans-serif;
            background: #efe7d6;
          }
        </style>
    {% endblock %}
</head>
<body>
    {% block body %}{% endblock %}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>
